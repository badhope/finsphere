# 生产环境配置
# ⚠️ 警告：生产环境部署前必须配置以下环境变量
# 不要在此文件中存储真实的密钥！

VITE_APP_TITLE=DATA
VITE_APP_DESCRIPTION=Enterprise Data Management Platform
VITE_BASE_URL=/

# API配置
VITE_API_BASE_URL=
VITE_MOCK_ENABLED=false

# 安全配置 (⚠️ 必须通过CI/CD或容器环境变量注入)
VITE_ENCRYPTION_KEY=
VITE_TOKEN_EXPIRES_IN=3600

# 功能开关
VITE_ENABLE_PWA=true
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_LOGGING=false

# 第三方服务
VITE_AMAP_KEY=
VITE_SENTRY_DSN=

# 性能配置
VITE_GZIP_COMPRESSION=true
VITE_CHUNK_SIZE_WARNING_LIMIT=2000
