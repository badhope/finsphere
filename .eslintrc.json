{
  "root": true,
  "env": {
    "browser": true,
    "es2021": true,
    "node": true
  },
  "extends": [
    "eslint:recommended",
    "plugin:vue/vue3-recommended",
    "prettier"
  ],
  "parser": "vue-eslint-parser",
  "parserOptions": {
    "ecmaVersion": "latest",
    "parser": "@typescript-eslint/parser",
    "sourceType": "module"
  },
  "plugins": ["vue"],
  "overrides": [
    {
      "files": ["src/**/*.vue", "src/**/*.ts"],
      "rules": {
        "no-undef": "off",
        "no-unused-vars": "off"
      }
    },
    {
      "files": ["*.test.ts", "tests/**/*.ts"],
      "rules": {
        "no-unused-vars": "off"
      }
    },
    {
      "files": ["vite.config.ts"],
      "rules": {
        "no-unused-vars": "off"
      }
    }
  ],
  "rules": {
    "vue/multi-word-component-names": "off",
    "vue/no-v-html": "off"
  }
}
