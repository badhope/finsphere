# 应用基本信息
VITE_APP_TITLE=DATA
VITE_APP_DESCRIPTION=Enterprise Data Management Platform
VITE_BASE_URL=/

# API配置
VITE_API_BASE_URL=http://localhost:8000
VITE_MOCK_ENABLED=true

# 安全配置 (⚠️ 生产环境必须修改！使用 openssl rand -hex 32 生成)
VITE_ENCRYPTION_KEY=
VITE_TOKEN_EXPIRES_IN=7200

# 功能开关
VITE_ENABLE_PWA=true
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_LOGGING=true

# 第三方服务
VITE_AMAP_KEY=
VITE_SENTRY_DSN=

# 性能配置
VITE_GZIP_COMPRESSION=true
VITE_CHUNK_SIZE_WARNING_LIMIT=2000
