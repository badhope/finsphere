      "code-rag": "mcp/code-rag/index.ts",
      "colors": "mcp/colors/index.ts",
      "compression": "mcp/compression/index.ts",
      "csv": "mcp/csv/index.ts",
      "datetime": "mcp/datetime/index.ts",
      "diff": "mcp/diff/index.ts",
      "encoding": "mcp/encoding/index.ts",
      "env": "mcp/env/index.ts",
      "fun": "mcp/fun/index.ts",
      "json": "mcp/json/index.ts",
      "markdown": "mcp/markdown/index.ts",
      "math": "mcp/math/index.ts",
      "network": "mcp/network/index.ts",
      "random": "mcp/random/index.ts",
      "regex": "mcp/regex/index.ts",
      "yaml": "mcp/yaml/index.ts"
    }
  },
  "author": "Trae Skills Team",
  "license": "Apache-2.0",
  "homepage": "https://skills.trae.dev",
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "yaml": "^2.4.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "@typescript-eslint/parser": "^7.6.0",
    "eslint": "^8.57.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vitest": "^1.5.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
