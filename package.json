      "mongodb": "mcp/mongodb/index.ts",
      "redis": "mcp/redis/index.ts",
      "sentry": "mcp/sentry/index.ts",
      "puppeteer": "mcp/puppeteer/index.ts",
      "aliyun": "mcp/aliyun/index.ts",
      "kubernetes": "mcp/kubernetes/index.ts",
      "aws": "mcp/aws/index.ts",
      "ssh": "mcp/ssh/index.ts",
      "npm": "mcp/npm/index.ts",
      "memory": "mcp/memory/index.ts",
      "vector": "mcp/vector/index.ts",
      "prompt": "mcp/prompt/index.ts",
      "agent": "mcp/agent/index.ts",
      "agent-autonomous": "mcp/agent-autonomous/index.ts",
      "agent-multi": "mcp/agent-multi/index.ts",
      "agent-reflection": "mcp/agent-reflection/index.ts",
      "website-builder": "mcp/website-builder/index.ts",
      "web-search": "mcp/web-search/index.ts",
