{
  "name": "data",
  "version": "2.0.0",
  "description": "Enterprise-grade data management platform with AI-powered analytics and financial insights",
  "author": "FinSphere Team",
  "license": "MIT",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
    "lint:style": "stylelint \"**/*.{css,scss,vue}\" --fix",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "coverage": "vitest run --coverage",
    "type-check": "vue-tsc --noEmit",
    "prepare": "husky",
    "commit": "cz",
    "release": "standard-version",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "@vueuse/core": "^10.9.0",
    "axios": "^1.6.8",
    "crypto-js": "^4.2.0",
    "dayjs": "^1.11.10",
    "echarts": "^5.5.0",
    "element-plus": "^2.6.1",
    "file-saver": "^2.0.5",
    "js-cookie": "^3.0.5",
    "lodash-es": "^4.17.21",
    "pinia": "^2.1.7",
    "qs": "^6.12.0",
    "uuid": "^9.0.1",
    "vue": "^3.4.21",
    "vue-echarts": "^6.6.9",
    "vue-i18n": "^9.10.1",
    "vue3-lottie": "^3.2.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@rushstack/eslint-patch": "^1.7.2",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/vue": "^8.0.2",
    "@types/crypto-js": "^4.2.2",
    "@types/eslint": "^8.56.5",
    "@types/file-saver": "^2.0.7",
    "@types/js-cookie": "^3.0.6",
    "@types/lodash-es": "^4.17.12",
    "@types/mockjs": "^1.0.10",
    "@types/node": "^20.11.28",
    "@types/nprogress": "^0.2.3",
    "@types/qs": "^6.9.12",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-vue": "^5.0.4",
    "@vitejs/plugin-vue-jsx": "^3.1.0",
    "@vitest/coverage-v8": "^1.4.0",
    "@vitest/ui": "^1.4.0",
    "commitizen": "^4.3.0",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-vue": "^9.22.0",
    "husky": "^9.0.11",
    "jsdom": "^28.1.0",
    "lint-staged": "^15.2.2",
    "mockjs": "^1.1.0",
    "prettier": "^3.2.5",
    "sass": "^1.71.1",
    "standard-version": "^9.5.0",
    "stylelint": "^16.2.1",
    "stylelint-config-html": "^1.1.0",
    "stylelint-config-recommended-vue": "^1.5.0",
    "stylelint-config-standard": "^36.0.0",
    "typescript": "^5.4.3",
    "unplugin-auto-import": "^0.17.5",
    "unplugin-vue-components": "^0.26.0",
    "vite": "^5.2.6",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-inspect": "^0.8.3",
    "vite-plugin-mock": "^3.0.2",
    "vite-plugin-pwa": "^0.19.2",
    "vitepress": "^1.0.1",
    "vitest": "^1.4.0",
    "vue-tsc": "^2.0.6"
  },
  "lint-staged": {
    "*.{vue,js,jsx,cjs,mjs,ts,tsx,cts,mts}": [
      "eslint --fix"
    ],
    "*.{css,scss,vue}": [
      "stylelint --fix"
    ]
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "keywords": [
    "vue3",
    "typescript",
    "financial",
    "dashboard",
    "admin",
    "enterprise",
    "analytics",
    "trading"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/badhope/finsphere.git"
  },
  "bugs": {
    "url": "https://github.com/badhope/finsphere/issues"
  },
  "homepage": "https://github.com/badhope/finsphere#readme"
}
