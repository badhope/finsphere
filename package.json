{
  "name": "skills",
  "version": "3.0.0",
  "type": "module",
  "description": "MCP Mega-Agent Platform - 11 Expert Engines + 80+ Professional Tools for ALL LLMs",
  "main": "./dist/packages/core/index.js",
  "types": "./dist/packages/core/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/packages/core/index.js",
      "types": "./dist/packages/core/index.d.ts"
    },
    "./mcp/*": {
      "import": "./dist/mcp/*/index.js",
      "types": "./dist/mcp/*/index.d.ts"
    },
    "./builder": {
      "import": "./dist/packages/core/mcp/builder.js",
      "types": "./dist/packages/core/mcp/builder.d.ts"
    }
  },
  "bin": {
    "skills": "./packages/cli/index.js"
  },
  "files": [
    "dist/",
    "packages/cli/"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "skill:list": "node packages/cli/index.js mcp",
    "skill:tools": "node packages/cli/index.js mcp-tools",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/badhope/skills.git"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "skills",
    "ai",
    "llm",
    "agent",
    "claude",
    "cursor",
    "windsurf",
    "cline",
    "trae",
    "mega-agent",
    "expert-system",
    "ide"
  ],
  "author": "badhope",
  "license": "MIT",
  "trae": {
    "type": "mcp-skill",
    "version": "3.0.0",
    "entrypoint": "packages/cli/index.js",
    "marketplace": {
      "categories": [
        "AI Agents",
        "Development",
        "Code Quality",
        "Workflow",
        "Productivity"
      ],
      "featured": true,
      "badges": [
        "MCP Standard",
        "Multi-Platform",
        "Productivity"
      ]
    },
    "mcpServers": {
