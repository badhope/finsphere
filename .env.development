# 应用基本信息
VITE_APP_TITLE=DATA
VITE_APP_DESCRIPTION=Enterprise Data Management Platform
VITE_BASE_URL=/

# API配置
VITE_API_BASE_URL=http://localhost:8000
VITE_MOCK_ENABLED=true

# 安全配置
VITE_ENCRYPTION_KEY=fin_sphere_secret_key_2024
VITE_TOKEN_EXPIRES_IN=7200

# 功能开关
VITE_ENABLE_PWA=true
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_LOGGING=true

# 第三方服务
VITE_AMAP_KEY=your_amap_api_key_here
VITE_SENTRY_DSN=your_sentry_dsn_here

# 性能配置
VITE_GZIP_COMPRESSION=true
VITE_CHUNK_SIZE_WARNING_LIMIT=2000